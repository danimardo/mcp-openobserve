{
  "name": "mcp-openobserve",
  "version": "1.0.0",
  "description": "Servidor MCP de solo lectura que actúa como intermediario entre agentes IA y el Log Gateway API",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "lint": "eslint src tests",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "25.9.2",
    "@vitest/coverage-v8": "4.1.8",
    "eslint": "10.4.1",
    "eslint-config-prettier": "^9.0.0",
    "prettier": "3.8.3",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "4.1.8"
  }
}
